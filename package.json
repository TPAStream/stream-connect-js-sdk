{
  "name": "stream-connect-sdk",
  "version": "0.8.1",
  "description": "A JavaScript SDK implementing TPAStream's Connect Platform",
  "scripts": {
    "build": "webpack --config webpack.prod-sdk.js --mode=production",
    "format": "biome check --write assets/",
    "test:lint": "biome check assets/",
    "test:types": "tsc --noEmit",
    "test": "npm run test:lint && npm run test:types",
    "screenshots": "node scripts/screenshots/capture.mjs",
    "screenshots:preview": "node scripts/screenshots/preview.mjs",
    "screenshots:upload": "node scripts/screenshots/upload.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:TPAStream/stream-connect-js-sdk.git"
  },
  "author": "TPAStreamOrg",
  "devDependencies": {
    "@babel/cli": "^7.27.1",
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.1",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.2",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "webpack": "^5.99.5",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@hookform/resolvers": "^3.10.0",
    "axios": "^1.7.9",
    "dompurify": "^3.2.4",
    "marked": "^15.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "zod": "^3.24.2"
  },
  "bugs": {
    "url": "https://github.com/TPAStream/stream-connect-js-sdk/issues"
  },
  "homepage": "https://github.com/TPAStream/stream-connect-js-sdk#readme",
  "main": "sdk.js",
  "exports": {
    ".": "./sdk.js",
    "./headless": "./sdk-headless.js"
  },
  "files": [
    "sdk.js",
    "sdk-headless.js",
    "README.md",
    "CHANGELOG.md",
    "docs/"
  ],
  "keywords": [
    "sdk"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=20"
  }
}
